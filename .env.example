# ============================================================
# LSHI-IA-VENDEUR — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# Sur Railway : Settings > Variables (ne jamais commiter .env)
# ============================================================

# Clé API Anthropic (Claude Vision + réponses IA)
# Obtenir sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REMPLACE_PAR_TA_VRAIE_CLE

# URL publique de TON déploiement Railway (rempli après déploiement)
# Exemple : https://lshi-ia-vendeur-production.up.railway.app
RAILWAY_PUBLIC_URL=https://TON_APP.up.railway.app

# Informations boutique (utilisées par le bot)
BOUTIQUE_NOM=Lshi-IA-Vendeur
BOUTIQUE_ADRESSE=Centre-Ville de Lubumbashi, avenue de la Libération
BOUTIQUE_HORAIRES=Lundi-Samedi 8h30-17h30
